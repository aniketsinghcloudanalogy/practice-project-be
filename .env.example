PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=verify-full

# JWT
JWT_ACCESS_SECRET=your-strong-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=1

# Internal secret shared with Next.js client
INTERNAL_AUTH_SECRET=your-strong-random-secret

# CORS — set to your Vercel frontend URL in production
CLIENT_URL=http://localhost:3000

# SMTP (optional — contact form email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
CONTACT_RECEIVER=receiver@example.com


GROQ_API_KEY=API key
GROQ_MODEL=Model
GROQ_MAX_TOKENS=2000