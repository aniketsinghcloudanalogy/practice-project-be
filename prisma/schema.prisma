model Product {
  id          Int      @id @default(autoincrement())
  name        String?
  description String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lineItems               LineItem[]
  profitabilty_line_items Profitabilty_line_items[]

  @@index([isDeleted])
}

model Bundle {
  id          Int      @id @default(autoincrement())
  name        String?
  description String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lineItems               LineItem[]
  profitabilty_line_items Profitabilty_line_items[]

  @@index([isDeleted])
}

model QuoteConfigurationModel {
  id        Int      @id @default(autoincrement())
  name      String?
  config    Json?
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems               LineItem[]                @relation("LineItemQuoteConfig")
  profitabilty_line_items Profitabilty_line_items[] @relation("ProfitabiltyLineItemQuoteConfig")

  @@index([isDeleted])
}

//customer schema
model Customer {
  id                      String                    @id @default(cuid())
  userId                  String
  name                    String?
  currency                String?
  website                 String?
  industry                String?
  profileImage            String?
  organization            String?
  isDeleted               Boolean                   @default(false)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  user                    User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunities           Opportunity[]
  addresses               Address[]
  contacts                UserContact[]
  quotes                  Quote[]
  lineItems               LineItem[]                @relation("LineItemCustomer")
  profitabilty_line_items Profitabilty_line_items[] @relation("ProfitabiltyLineItemCustomer")

  @@index([userId])
  @@index([isDeleted])
}

//opportunity schema
model Opportunity {
  id            String  @id @default(cuid())
  userId        String
  customerId    String
  opportunityId String?

  syncedQuote                  Int?
  organization                 String?
  title                        String?
  amount                       Float?
  pdfUrl                       String[]
  description                  String?
  closeDate                    String?
  expectedPrice                Float?
  addShipment                  Boolean  @default(false)
  rfqRfiNumber                 String?
  periodOfPerformanceStartDate String?
  periodOfPerformanceEndDate   String?
  probability                  Int?
  isDeleted                    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  parent   Opportunity?  @relation("OpportunityParentChild", fields: [opportunityId], references: [id], onDelete: SetNull)
  children Opportunity[] @relation("OpportunityParentChild")
  quotes   Quote[]

  @@index([userId])
  @@index([customerId])
  @@index([opportunityId])
  @@index([isDeleted])
}

//address schema
model Address {
  id                String      @id @default(cuid())
  userId            String
  customerId        String?
  addressLine       String
  city              String
  state             String
  zipCode           String
  country           String
  type              AddressType
  isDefaultShipping Boolean     @default(false)
  isDefaultBilling  Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  isDeleted         Boolean     @default(false)
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer          Customer?   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([customerId])
  @@index([userId, type])
}

model SavedLocation {
  id         String   @id @default(cuid())
  userId     String
  label      String?
  latitude   Float
  longitude  Float
  shareToken String   @unique @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sharedWith SharedLocation[]

  @@index([userId])
  @@index([shareToken])
}

model SharedLocation {
  id         String        @id @default(cuid())
  locationId String
  sharedById String
  sharedToId String
  createdAt  DateTime      @default(now())
  location   SavedLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  sharedBy   User          @relation("SharedByUser", fields: [sharedById], references: [id], onDelete: Cascade)
  sharedTo   User          @relation("SharedToUser", fields: [sharedToId], references: [id], onDelete: Cascade)

  @@unique([locationId, sharedToId])
  @@index([sharedById])
  @@index([sharedToId])
}

model Meeting {
  id String @id @default(cuid())

  title       String
  description String?

  startTime DateTime
  endTime   DateTime

  location   String?
  meetingUrl String?

  status      MeetingStatus   @default(SCHEDULED)
  priority    MeetingPriority @default(MEDIUM)
  meetingType MeetingType     @default(INTERNAL)
  department  String?

  organizerId String
  organizer   User   @relation("MeetingOrganizer", fields: [organizerId], references: [id], onDelete: Restrict)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  participants MeetingParticipant[]

  // --- Recurrence support ---
  recurrenceRule       String? // iCal RRULE string, e.g. "FREQ=WEEKLY;BYDAY=MO,WE"
  recurrenceEndDate    DateTime?
  parentMeetingId      String?
  parentMeeting        Meeting?  @relation("RecurrenceInstances", fields: [parentMeetingId], references: [id], onDelete: Cascade)
  recurringInstances   Meeting[] @relation("RecurrenceInstances")
  isRecurringException Boolean   @default(false) // true if this instance was individually edited

  reminderSentAt DateTime?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notifications Notification[]

  @@unique([parentMeetingId, startTime])
  @@index([organizerId])
  @@index([organizationId])
  @@index([startTime])
  @@index([status, startTime])
  @@index([department])
  @@index([status, department, startTime])
  @@index([organizerId, isDeleted, startTime])
  @@index([parentMeetingId])
}

model MeetingParticipant {
  id String @id @default(cuid())

  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  responseStatus ResponseStatus @default(PENDING)

  joinedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  meetingId String?
  meeting   Meeting? @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  title String

  message String

  type NotificationType

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
}

